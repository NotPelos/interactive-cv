# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

set -e

# Find the project base dir
MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-""}
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR=$(pwd)
  while true; do
    if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties" ]; then
      break
    fi
    PARENT=$(dirname "$MAVEN_PROJECTBASEDIR")
    if [ "$PARENT" = "$MAVEN_PROJECTBASEDIR" ]; then
      MAVEN_PROJECTBASEDIR=$(pwd)
      break
    fi
    MAVEN_PROJECTBASEDIR=$PARENT
  done
fi

MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Read the wrapperUrl from properties
WRAPPER_URL=""
if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
  WRAPPER_URL=$(grep "^wrapperUrl=" "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2-)
fi

# Download the wrapper jar if it does not exist
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  if command -v curl > /dev/null 2>&1; then
    echo "Downloading Maven Wrapper from $WRAPPER_URL"
    curl -o "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL" -f -L --create-dirs 2>/dev/null || \
      curl -o "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL" -L --create-dirs
  elif command -v wget > /dev/null 2>&1; then
    echo "Downloading Maven Wrapper from $WRAPPER_URL"
    wget -O "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL"
  else
    echo "ERROR: curl or wget is required to download the Maven Wrapper"
    exit 1
  fi
fi

# Determine JAVA_HOME / java executable
if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
elif command -v java > /dev/null 2>&1; then
  JAVACMD="java"
else
  echo "ERROR: JAVA_HOME is not set and java is not in PATH."
  exit 1
fi

exec "$JAVACMD" \
  -classpath "$MAVEN_WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
