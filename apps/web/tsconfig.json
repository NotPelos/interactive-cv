{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "exclude": [
    "node_modules",
    "dist",
    "playwright-report",
    "test-results",
    ".astro"
  ]
}
