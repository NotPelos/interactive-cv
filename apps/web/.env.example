# Endpoints de los servicios externos.
# Copia este archivo a .env.local para desarrollo local.
#
# Astro expone al cliente solo las variables con prefijo PUBLIC_.
# En el componente Terminal se usan via import.meta.env.PUBLIC_API_URL, etc.
#
# Sin ENV (vacío) → comandos download y repos van al fallback estático.
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WORKER_URL=http://localhost:8787
