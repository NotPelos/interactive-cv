---
import { getCollection } from "astro:content";
import Terminal from "../components/Terminal.tsx";
import { buildFsFromContent, assertFsParity } from "../lib/fs/seed.js";
import type { ContentEntry } from "../lib/fs/seed.js";
import type { SkillsData, Endpoints } from "../lib/commands/types.js";
import skillsRaw from "../content/skills/skills.json";
import { skillsSchema } from "../content.config.ts";
import "../styles/global.css";

// Endpoints de servicios externos. Leídos desde variables de entorno en build time
// y pasados al island Terminal como prop. Astro expone al cliente solo las vars PUBLIC_.
// Si no están definidas, se usan strings vacíos y el Terminal entra en modo degradado:
//   - download cv.pdf → abre PDF estático en /cv-static-{lang}.pdf
//   - repos → informa de modo degradado, sin fetch
const endpoints: Endpoints = {
  api: import.meta.env.PUBLIC_API_URL ?? "",
  worker: import.meta.env.PUBLIC_WORKER_URL ?? "",
};

// Build virtual FS from content collections at build/SSR time.
const aboutEntries = await getCollection("about");
const experienceEntries = await getCollection("experience");
const projectsEntries = await getCollection("projects");
const educationEntries = await getCollection("education");

// Validate skills.json shape at build time — throws with a clear Zod error if malformed.
const skillsData = skillsSchema.parse(skillsRaw) as unknown as SkillsData;

// Map Astro CollectionEntry to the internal shape
function toContentEntry(e: { id: string; body?: string; data: Record<string, unknown> }): ContentEntry {
  return { id: e.id, body: e.body, data: e.data };
}

const allCollections = {
  about: aboutEntries.map(toContentEntry),
  experience: experienceEntries.map(toContentEntry),
  projects: projectsEntries.map(toContentEntry),
  education: educationEntries.map(toContentEntry),
  skillsJson: skillsData as unknown as Record<string, unknown>,
};

// Build one FS per language at build time — zero runtime cost
const initialFsByLang = {
  es: buildFsFromContent(allCollections, "es"),
  en: buildFsFromContent(allCollections, "en"),
};

// Valida simetría de paths entre ambos idiomas. Lanza en build si divergen.
assertFsParity(initialFsByLang.es, initialFsByLang.en);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>notpelos@cv</title>
    <meta name="description" content="CV interactivo de NotPelos — desarrollador backend Java." />
  </head>
  <body class="bg-tn-bg text-tn-text font-mono min-h-screen overflow-x-hidden">

    <!-- Chrome bar: dots + URL + recruiter button -->
    <header class="sticky top-0 z-10 bg-tn-elev border-b border-tn-border flex items-center justify-between px-4 py-2">
      <!-- macOS-style traffic lights (decorative) -->
      <div class="flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-full bg-tn-red"></span>
        <span class="inline-block w-3 h-3 rounded-full bg-tn-yellow"></span>
        <span class="inline-block w-3 h-3 rounded-full bg-tn-green"></span>
        <span class="ml-3 text-tn-text-dim text-sm">notpelos.pages.dev</span>
      </div>

      <!-- Recruiter escape hatch -->
      <a
        href="/cv"
        class="text-tn-blue text-sm hover:text-tn-text transition-colors"
        title="Vista clásica para reclutadores"
      >
        👔 recruiter
      </a>
    </header>

    <!-- Terminal island (all interaction happens here) -->
    <!-- endpoints: si alguna URL es vacía, los comandos download y repos usan fallback estático -->
    <main>
      <Terminal
        client:load
        initialFsByLang={initialFsByLang}
        skillsData={skillsData}
        defaultLang="es"
        endpoints={endpoints}
      />
    </main>

    <!-- Hint for non-devs (bilingual) -->
    <p class="text-tn-text-dim text-xs text-center pb-2 select-none pointer-events-none">
      // no eres dev? escribe `recruiter` o pulsa 👔 · not a dev? type `recruiter` or tap 👔
    </p>

  </body>
</html>
