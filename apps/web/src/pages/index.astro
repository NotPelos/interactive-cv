---
import Terminal from "../components/Terminal.tsx";
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>notpelos@cv</title>
    <meta name="description" content="CV interactivo de NotPelos — desarrollador backend Java." />
  </head>
  <body class="bg-tn-bg text-tn-text font-mono min-h-screen overflow-x-hidden">

    <!-- Chrome bar: dots + URL + recruiter button -->
    <header class="sticky top-0 z-10 bg-tn-elev border-b border-tn-border flex items-center justify-between px-4 py-2">
      <!-- macOS-style traffic lights (decorative) -->
      <div class="flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-full bg-tn-red"></span>
        <span class="inline-block w-3 h-3 rounded-full bg-tn-yellow"></span>
        <span class="inline-block w-3 h-3 rounded-full bg-tn-green"></span>
        <span class="ml-3 text-tn-text-dim text-sm">notpelos.pages.dev</span>
      </div>

      <!-- Recruiter escape hatch — links to /cv (Fase 3 follow-up: 404 until built) -->
      <a
        href="/cv"
        class="text-tn-blue text-sm hover:text-tn-text transition-colors"
        title="Vista clásica para reclutadores"
      >
        👔 recruiter
      </a>
    </header>

    <!-- Terminal island (all interaction happens here) -->
    <main>
      <Terminal client:load />
    </main>

  </body>
</html>
