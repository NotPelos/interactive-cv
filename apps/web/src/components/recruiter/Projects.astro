---
import { getCollection } from "astro:content";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;

const allProjects = await getCollection("projects");

// Top 4 by order (1 = most sellable): AuthServiceGame, NosRaids, RustEagle,
// dle Dragon Ball. Layout 2×2 da más respiración por card que un 3+1 col.
const projects = allProjects
  .filter((p) => p.data.lang === lang && p.data.order <= 4)
  .sort((a, b) => a.data.order - b.data.order);

// Warn at build time if a project exposes neither repo nor liveUrl.
for (const p of projects) {
  if (!p.data.repo && !p.data.liveUrl) {
    console.warn(
      `[Projects] "${p.data.title}" (${p.data.lang}) has no repo or liveUrl — card will render without links.`
    );
  }
}
---

<section aria-labelledby="projects-heading">
  <h2
    id="projects-heading"
    class="text-xs uppercase tracking-[0.15em] text-tn-blue font-medium mb-3 pb-1 border-b border-tn-border"
  >
    {lang === "es" ? "Proyectos" : "Projects"}
  </h2>

  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {projects.map((p) => (
      <li class="border border-tn-border rounded-md p-4 flex flex-col gap-2">
        <div>
          <h3 class="text-sm font-medium text-tn-text">{p.data.title}</h3>
          <p class="text-xs text-tn-cyan mt-0.5 leading-snug">{p.data.pitch}</p>
        </div>

        {/* Stack pills */}
        <ul class="flex flex-wrap gap-1" aria-label="Stack">
          {p.data.stack.map((tech) => (
            <li class="text-[10px] uppercase tracking-wider border border-tn-border rounded px-2 py-0.5 text-tn-text-dim">
              {tech}
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap gap-3 mt-auto">
          {p.data.liveUrl && (
            <a
              href={p.data.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-tn-green hover:text-tn-blue transition-colors"
              aria-label={`${lang === "es" ? "Demo en vivo de" : "Live demo for"} ${p.data.title}`}
            >
              {lang === "es" ? "demo en vivo →" : "live demo →"}
            </a>
          )}
          {p.data.repo && (
            <a
              href={p.data.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-tn-magenta hover:text-tn-blue transition-colors"
              aria-label={`${lang === "es" ? "Repositorio de" : "Repository for"} ${p.data.title}`}
            >
              {lang === "es" ? "ver repo →" : "view repo →"}
            </a>
          )}
        </div>
      </li>
    ))}
  </ul>
</section>
