---
import { getCollection, render } from "astro:content";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;

const allExp = await getCollection("experience");
const entries = allExp
  .filter((e) => e.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

// Format date range: "2023-01" → "Ene 2023" (ES) or "Jan 2023" (EN)
function formatDate(ym: string, l: "es" | "en"): string {
  if (ym === "present") return l === "es" ? "presente" : "present";
  const [year, month] = ym.split("-");
  const date = new Date(Number(year), Number(month) - 1, 1);
  return date.toLocaleDateString(l === "es" ? "es-ES" : "en-GB", {
    month: "short",
    year: "numeric",
  });
}

// Pre-render each entry body at build time
const rendered = await Promise.all(
  entries.map(async (e) => {
    const { Content } = await render(e);
    return { entry: e, Content };
  })
);
---

<section aria-labelledby="experience-heading">
  <h2
    id="experience-heading"
    class="text-xs uppercase tracking-[0.15em] text-tn-blue font-medium mb-4 pb-1 border-b border-tn-border"
  >
    {lang === "es" ? "Experiencia" : "Experience"}
  </h2>

  <ol class="relative border-l border-tn-border ml-3 space-y-8" aria-label={lang === "es" ? "Historial de experiencia" : "Experience history"}>
    {rendered.map(({ entry, Content }) => {
      const { company, role, start, end, location, client, stack, testimonial } = entry.data;
      const startFmt = formatDate(start, lang);
      const endFmt = formatDate(end, lang);
      const dateRange = `${startFmt} → ${endFmt}`;

      return (
        <li class="experience-entry ml-6 relative">
          {/* Timeline node */}
          <span
            class="absolute -left-[1.65rem] top-1 w-3 h-3 rounded-full bg-tn-blue border-2 border-tn-bg"
            aria-hidden="true"
          />

          <header class="mb-2">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
              <h3 class="text-sm font-medium text-tn-magenta">{company}</h3>
              <span class="text-sm text-tn-text-mute">— {role}</span>
            </div>

            <p class="text-xs text-tn-text-dim mt-0.5">
              <time>{dateRange}</time>
              <span aria-hidden="true"> · </span>
              <span>{location}</span>
              {client && (
                <>
                  <span aria-hidden="true"> · </span>
                  <span class="italic">({lang === "es" ? "cliente" : "client"}: {client})</span>
                </>
              )}
            </p>
          </header>

          <div class="prose-exp text-xs text-tn-text-mute leading-relaxed mb-2">
            <Content />
          </div>

          {testimonial && (
            <blockquote class="border-l-2 border-tn-blue pl-3 my-2">
              <p class="text-[11px] italic text-tn-text-mute leading-relaxed">
                "{testimonial.quote}"
              </p>
              <footer class="text-[10px] mt-1">
                <span class="text-tn-magenta">— {testimonial.attribution}</span>
                <span class="text-tn-text-dim">, {testimonial.role}</span>
              </footer>
            </blockquote>
          )}

          {/* Stack pills */}
          <ul class="flex flex-wrap gap-1.5" aria-label="Stack">
            {stack.map((tech) => (
              <li class="text-[10px] uppercase tracking-wider border border-tn-border rounded px-2 py-0.5 text-tn-text-dim">
                {tech}
              </li>
            ))}
          </ul>
        </li>
      );
    })}
  </ol>
</section>

<style>
  .prose-exp :global(p) {
    margin-bottom: 0.4rem;
  }

  .prose-exp :global(ul) {
    list-style: disc;
    padding-left: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .prose-exp :global(li) {
    margin-bottom: 0.2rem;
  }

  .prose-exp :global(strong) {
    color: #c0caf5; /* tn-text */
    font-weight: 500;
  }

  .prose-exp :global(em) {
    color: #7a839e; /* tn-text-dim — actualizado a ≥ 4.5:1 WCAG AA */
    font-style: italic;
  }
</style>
